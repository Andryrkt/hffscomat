{% extends "baseTemplate.html.twig" %}

{% block title %}
	Magasin - Soumission commandes fournisseur à génerer
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ App.base_path }}/Views/css/list.css?v=2025.10.22.08.00">
	<link rel="stylesheet" href="{{ App.base_path }}/Views/css/new.css?v=2025.10.22.08.00">
	<link rel="stylesheet" href="{{ App.base_path }}/Views/css/magasin/magasin.css?v=2025.10.22.08.00">
{% endblock %}


{% block content %}
	<div class="container-spaced mt-6 mb-4">
		<div class="card p-3">
			<h3 class="perso-titre">Soumission commandes fournisseur à génerer</h3>
			{% include "/partials/_notification.html.twig" %}
			{{ form_start(form , { 'attr': { 'id': 'myForm' } }) }}
			{{ form_errors(form)}}
			<div class="row mt-2">
				<div class="align-items-center">
					<div class="col-md-3 mb-2">
						<div class="row align-items-center">
							{{ form_label(form.numCmde) }}
							<div class="col-6">
								{{ form_widget(form.numCmde) }}
							</div>
							<div class="col-6">
								<button type="button" class="btn bouton-brouillon border text-black" id="genererPdf">
									<i class="fa-solid fa-file-pdf"></i>
									Générer PDF
								</button>
							</div>
						</div>
					</div>
					<div id="viewer-container" class="d-none">
						<div id="file-viewer" class="position-relative w-100 border rounded overflow-hidden" style="height:1000px;">
							<iframe id="pdf-iframe" name="pdf-iframe" src="" class="position-absolute top-0 start-0 w-100 h-100 border-0"></iframe>
						</div>
					</div>
				</div>
				<div class="d-flex justify-content-end mt-2">
					<button type="submit" class="bouton-principal" id="validationBtn" style="display:none ;">
						<i class="fas fa-paper-plane"></i>
						Soumettre à validation
					</button>
				</div>
			</div>
			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}

{% block javascript %}
	<script src="{{ App.base_path }}/Views/js/magasin/commande/soumissionCommandeFournisseur.js?v=2025.10.22.08.00" type="module"></script>
{% endblock %}
