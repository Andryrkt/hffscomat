<!-- DEBUT recherche -->
<div class="accordion" id="formAccordion">
	<div class="accordion-item">
		<h2 class="accordion-header">
			<button class="accordion-button enteteAccordion" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
				Formulaire de recherche
			</button>
		</h2>
		<div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#formAccordion">
			<div class="accordion-body">
				{{ form_start(form, {'method': 'GET'}) }}
				<div class="row">
					<div class="col-12 col-md-2">
						{{ form_row(form.numeroDevis) }}
						{{ form_row(form.codeClient) }}
						<div id="suggestion-code-client" class="suggestions-container"></div>
						<div id="loader-code-client" class="spinner" style="display: none;">Chargement...</div>
						{{ form_row(form.filterRelance)}}

					</div>
					<div class="col-12 col-md-2">
						{{ form_row(form.Operateur) }}
						{{ form_row(form.CreePar) }}
					</div>

					<div class="col-12 col-md-2">
						{% if form.emetteur is defined %}
							{{form_row(form.emetteur.agence)}}
							{{form_row(form.emetteur.service)}}
						{% else %}
							{{form_row(form.agenceEmetteur)}}
							{{form_row(form.serviceEmetteur)}}
						{% endif %}
					</div>
					<div class="col-12 col-md-2">
						{{ form_row(form.dateCreation) }}
					</div>
					<div class="col-12 col-md-2">
						{{ form_row(form.statutDw) }}
						{{ form_row(form.statutIps) }}
					</div>
					<div class="col-12 col-md-2">
						{{ form_row(form.statutBc) }}
						{{ form_row(form.numeroPO) }}
					</div>
				</div>
				<div class="d-flex justify-content-end mb-2 gap-2">
					<button class="btn btn-secondary fw-bold" type="reset" id="btn-reset-form">
						<i class="fas fa-undo"></i>
						Effacer
					</button>
					<button class="btn btn-warning fw-bold" type="submit">
						<i class="fab fa-searchengin"></i>
						Recherche
					</button>
				</div>

				{{ form_end(form) }}
			</div>
		</div>
	</div>
</div>
<div class="row mt-2">
	<div class="col d-flex justify-content-between align-items-center">
		<a href="{{ path('export_excel_liste_devis_neg') }}" class="btn btn-sm bg-success text-white fw-bold afficher-overlay">
			<i class="fas fa-table"></i>
			Excel
		</a>
	</div>
</div>
