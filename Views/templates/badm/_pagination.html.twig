{% set listPathRedirect = annule ? "badmListe_AffichageListeBadm" : "badm_list_annuler" %}
{% set listPathActuel = annule ? "badm_list_annuler" : "badmListe_AffichageListeBadm" %}
{% set listTitle = annule ? "Liste des BADM" : "Liste des BADM Annulés" %}
{% set bgColor = annule ? "bg-warning" : "bg-danger" %}

<div class="d-flex justify-content-between">
	<div>
		<a href="{{path("export_badm_excel")}}" class="btn btn-sm bg-success text-white my-3 fw-bold afficher-overlay">
			<i class="fas fa-table"></i>
			Excel
		</a>

		<a href="{{ path(listPathRedirect) }}" class="btn btn-sm {{ bgColor }} text-white my-3 fw-bold">
			{{ listTitle }}
		</a>
	</div>
	<div>
		<p class="fw-bold my-3" id="nombreResultat">{{resultat}}
			Résultats</p>
	</div>
	<div>
		<p class="fw-bold my-3" id="nombreResultat">{{currentPage ~' / '~ (lastPage)}}
			pages</p>
	</div>
	<div class="navigation">
		{% set queryParams = criteria  %}

		{% if currentPage > 1 %}
			<a class="btn btn-dark my-3" href="{{ path(listPathActuel, queryParams|merge({'page': currentPage - 1})) }}">
				<i class="fas fa-angle-left text-warning"></i>
			</a>
		{% endif %}


		{% if currentPage < lastPage %}
			<a class="btn btn-dark" href="{{ path(listPathActuel, queryParams|merge({'page': currentPage + 1})) }}">
				<i class="fas fa-angle-right text-warning"></i>
			</a>
		{% endif %}
	</div>
</div>
